# Copy to .kamal/deploy.env and fill values for Zapfe deploys.
# Then run: set -a; source .kamal/deploy.env; set +a

# Docker registry
KAMAL_REGISTRY_PASSWORD=

# Rails app secrets
RAILS_MASTER_KEY=
SECRET_KEY_BASE=

# Mail / monitoring
RESEND_API_KEY=
MONITORING_TOKEN=replace_with_monitoring_token

# Optional video URLs (fallback is /videos/*.mp4 from public/)
# SOLUTIONS_FILM_URL=https://staging.zapfe.duzend.net/videos/hochzeit_bier_horizontal_720.mp4
# HUGO_VIDEO_URL=https://staging.zapfe.duzend.net/videos/hochzeit_hugo_vertical_720.mp4
