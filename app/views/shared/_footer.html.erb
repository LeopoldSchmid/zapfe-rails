<footer class="<%= footer_classes %>">
  <div class="mx-auto flex w-full max-w-7xl flex-col gap-4 px-4 py-6 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-2">
        <img src="/zapfe_b.svg" alt="Zapfe" class="h-8 w-auto" />
        <%= link_to "ZAPFE!", root_path, class: "text-lg font-bold text-[var(--color-zapfe-amber)]" %>
        <p class="text-sm text-white/65">Mobile Zapfanlagen zur Selbstbedienung.</p>
      </div>

      <div class="flex flex-wrap gap-x-4 gap-y-2 text-sm text-white/70">
        <%= link_to "Kontakt", contact_path, class: "hover:text-[var(--color-zapfe-amber)]" %>
        <%= link_to "Datenschutz", datenschutz_path, class: "hover:text-[var(--color-zapfe-amber)]" %>
        <%= link_to "Impressum", impressum_path, class: "hover:text-[var(--color-zapfe-amber)]" %>
      </div>
    </div>

    <div class="border-t border-white/12 pt-4 text-xs text-white/50">
      © <%= Date.current.year %> Zapfe!
    </div>
  </div>
</footer>
