<footer class="mt-20 bg-[var(--color-zapfe-navy)] text-white">
  <div class="mx-auto w-full max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-4">
      <div class="md:col-span-2">
        <div class="mb-4 flex items-center gap-2">
          <img src="/zapfe_b.svg" alt="Zapfe" class="h-10 w-auto" />
          <%= link_to "ZAPFE!", root_path, class: "text-2xl font-bold text-[var(--color-zapfe-amber)]" %>
        </div>
        <p class="max-w-md text-white/75">
          Premium mobile Zapfanlagen für Veranstaltungen aller Größen. Unsere Selbstbedienungs-Bierstationen bringen Komfort und Stil zu deinen Feierlichkeiten.
        </p>
      </div>

      <div>
        <h3 class="mb-4 text-lg font-semibold">Schnelllinks</h3>
        <ul class="space-y-2 text-white/75">
          <li><%= link_to "Startseite", root_path, class: "hover:text-[var(--color-zapfe-amber)]" %></li>
          <li><%= link_to "Preisrechner", calculator_path, class: "hover:text-[var(--color-zapfe-amber)]" %></li>
          <li><%= link_to "Veranstaltungen", events_path, class: "hover:text-[var(--color-zapfe-amber)]" %></li>
          <li><%= link_to "Getränke", drinks_path, class: "hover:text-[var(--color-zapfe-amber)]" %></li>
          <li><%= link_to "Kontakt", contact_path, class: "hover:text-[var(--color-zapfe-amber)]" %></li>
        </ul>
      </div>

      <div>
        <h3 class="mb-4 text-lg font-semibold">Kontaktiere uns</h3>
        <address class="not-italic text-white/75">
          <p>79104 Freiburg im Breisgau</p>
          <p>E-Mail: <a href="mailto:info@zapfe.jetzt" class="hover:text-[var(--color-zapfe-amber)]">info@zapfe.jetzt</a></p>
          <p>Telefon: <a href="tel:+491623473520" class="hover:text-[var(--color-zapfe-amber)]">+49 162 347 3520</a></p>
        </address>
      </div>
    </div>

    <div class="mt-8 flex flex-col items-center justify-between gap-4 border-t border-white/15 pt-8 text-sm text-white/60 md:flex-row">
      <p>© <%= Date.current.year %> Zapfe! Alle Rechte vorbehalten.</p>
      <div class="flex gap-4">
        <%= link_to "Datenschutz", datenschutz_path, class: "hover:text-[var(--color-zapfe-amber)]" %>
        <%= link_to "Impressum", impressum_path, class: "hover:text-[var(--color-zapfe-amber)]" %>
      </div>
    </div>
  </div>
</footer>
