<header class="fixed inset-x-0 top-0 z-40 shadow-sm" data-controller="mobile-menu">
  <div class="border-b border-[#d6b43f] bg-[var(--color-zapfe-amber)]">
    <div class="page-wrap flex h-14 items-center justify-between">
      <%= link_to root_path, class: "flex items-center gap-2" do %>
        <img src="/zapfe_b.svg" alt="Zapfe" class="h-8 w-auto" />
        <span class="text-xl font-extrabold tracking-tight text-[var(--color-zapfe-navy)]">ZAPFE!</span>
      <% end %>

      <nav class="hidden items-center gap-5 text-sm font-semibold text-[var(--color-zapfe-navy)] md:flex">
        <% desktop_links = [
          ["Startseite", root_path],
          ["Preisrechner", calculator_path],
          ["Veranstaltungen", events_path],
          ["Getränke", drinks_path],
          ["Kontakt", contact_path]
        ] %>
        <% desktop_links.each do |label, path| %>
          <%= link_to label, path, class: "#{current_page?(path) ? 'underline underline-offset-8' : ''}" %>
        <% end %>
      </nav>

      <button class="md:hidden text-[var(--color-zapfe-navy)]" data-action="mobile-menu#toggle" aria-label="Menü öffnen">
        <svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>
  </div>

  <div class="fixed inset-0 top-14 z-50 bg-[var(--color-zapfe-amber)] px-8 py-10 hidden md:hidden" data-mobile-menu-target="panel">
    <div class="mb-10 flex justify-end">
      <button class="text-[var(--color-zapfe-navy)]" data-action="mobile-menu#close" aria-label="Menü schließen">
        <svg viewBox="0 0 24 24" class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
    </div>
    <nav class="mx-auto flex max-w-xs flex-col gap-7 text-[var(--color-zapfe-navy)]">
      <% mobile_links = [
        ["Startseite", root_path, "M3 10.5 12 3l9 7.5v9.5a1 1 0 0 1-1 1h-5.5v-6h-5v6H4a1 1 0 0 1-1-1z"],
        ["Preisrechner", calculator_path, "M8 3h8M6 6h12a1 1 0 0 1 1 1v14H5V7a1 1 0 0 1 1-1zm3 5h6m-6 4h6"],
        ["Veranstaltungen", events_path, "M8 2v4m8-4v4M4 9h16M6 5h12a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2"],
        ["Getränke", drinks_path, "M8 5h8M7 5l1 14h8l1-14M9 9h6M10 13h4"],
        ["Kontakt", contact_path, "M4 7.5A2.5 2.5 0 0 1 6.5 5h11A2.5 2.5 0 0 1 20 7.5v9a2.5 2.5 0 0 1-2.5 2.5h-11A2.5 2.5 0 0 1 4 16.5zm0 .5 8 5 8-5"]
      ] %>
      <% mobile_links.each do |label, path, icon_path| %>
        <%= link_to path, data: { action: "mobile-menu#close" }, class: "flex items-center gap-3 text-3xl font-semibold #{current_page?(path) ? 'underline underline-offset-8' : ''}" do %>
          <svg viewBox="0 0 24 24" class="h-6 w-6 shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="<%= icon_path %>" />
          </svg>
          <span><%= label %></span>
        <% end %>
      <% end %>
    </nav>
  </div>
</header>
