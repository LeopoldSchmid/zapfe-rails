<section class="bg-slate-50 pt-8 pb-16 sm:pt-12 sm:pb-20">
  <div class="page-wrap">
    <div class="mx-auto max-w-4xl text-center">
      <span class="eyebrow-rule">Kontakt</span>
      <h1 class="mt-4 text-4xl font-bold leading-[1.04] text-[var(--color-zapfe-navy)] sm:text-6xl">
        Kontaktiere uns.
      </h1>
      <p class="mx-auto mt-5 max-w-3xl text-base leading-7 text-slate-600 sm:text-lg">
        Wenn dein Anliegen schon klar ist, geh direkt zur passenden Anfrage. Für alles Offene kannst du uns hier schriftlich oder gerne auch telefonisch frei kontaktieren.
      </p>
    </div>

    <div class="mx-auto mt-10 w-full max-w-4xl">
      <div class="cta-mini-grid">
        <%= link_to "#{events_path}#contact", class: "cta-mini cta-mini--event", aria: { label: "Veranstaltung" } do %>
          <span class="cta-mini__topline">
            <span class="cta-mini__tag">Event</span>
            <span class="cta-mini__arrow" aria-hidden="true">→</span>
          </span>
          <span class="cta-mini__title">Temporär</span>
        <% end %>

        <%= link_to "#{solutions_path}#contact", class: "cta-mini cta-mini--solutions", aria: { label: "Dauerhafter Betrieb" } do %>
          <span class="cta-mini__topline">
            <span class="cta-mini__tag">Betrieb</span>
            <span class="cta-mini__arrow" aria-hidden="true">→</span>
          </span>
          <span class="cta-mini__title">Dauerhaft</span>
        <% end %>
      </div>
      <div class="mt-5 grid gap-3 text-sm leading-6 text-slate-600 sm:grid-cols-2">
        <p>Für Vermietung, einzelne Einsätze, Getränkekonzepte und alles rund um Veranstaltungen.</p>
        <p>Für feste Lösungen, wiederkehrenden Ausschank und Produktanfragen.</p>
      </div>
    </div>
  </div>
</section>

<section id="free-contact" class="bg-white py-14 sm:py-18">
  <div class="page-wrap">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,0.9fr)_minmax(360px,1.1fr)] lg:items-start">
      <div class="space-y-5">
        <div class="max-w-2xl">
          <span class="eyebrow-rule">Anfrage</span>
          <h2 class="mt-4 text-3xl font-bold text-[var(--color-zapfe-navy)] sm:text-4xl">Noch nicht ganz sicher?</h2>
          <p class="mt-4 text-base leading-7 text-slate-600 sm:text-lg">
            Dann kontaktiere uns einfach.
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
          <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50 p-5">
            <div class="grid h-11 w-11 place-content-center rounded-xl bg-white text-[var(--color-zapfe-amber)] ring-1 ring-slate-200">
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="6" width="18" height="12" rx="2" />
                <path d="m4 8 8 6 8-6" />
              </svg>
            </div>
            <p class="mt-4 text-sm font-semibold uppercase tracking-[0.16em] text-slate-500">E-Mail</p>
            <p class="mt-2 text-lg font-semibold text-[var(--color-zapfe-navy)]">
              <a href="mailto:info@zapfe.jetzt" class="hover:underline">info@zapfe.jetzt</a>
            </p>
          </div>

          <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50 p-5">
            <div class="grid h-11 w-11 place-content-center rounded-xl bg-white text-[var(--color-zapfe-amber)] ring-1 ring-slate-200">
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 4h3l2 5-2 1.5a14 14 0 0 0 5.5 5.5L15 14l5 2v3a2 2 0 0 1-2.2 2A17 17 0 0 1 3 6.2 2 2 0 0 1 5 4z" />
              </svg>
            </div>
            <p class="mt-4 text-sm font-semibold uppercase tracking-[0.16em] text-slate-500">Telefon</p>
            <p class="mt-2 text-lg font-semibold text-[var(--color-zapfe-navy)]">
              <a href="tel:+491623473520" class="hover:underline">+49 162 347 3520</a>
            </p>
          </div>
        </div>
      </div>

      <div class="rounded-[1.8rem] border border-slate-200 bg-[var(--color-zapfe-cream)] p-5 shadow-[0_18px_44px_rgba(15,39,67,0.08)] sm:p-7">
        <h2 class="text-2xl font-semibold text-[var(--color-zapfe-navy)]">Kontaktformular</h2>
        <div class="mt-5">
          <%= render "inquiry_form", source: "contact" %>
        </div>
      </div>
    </div>
  </div>
</section>
