<section class="py-6 sm:py-8 reveal" data-controller="reveal">
  <div class="page-wrap grid gap-6 lg:grid-cols-2">
    <div class="card-soft p-5 sm:p-6">
      <h1 class="text-3xl font-bold text-[var(--color-zapfe-navy)]">Lass uns dein Event einordnen</h1>

      <div class="mt-6 space-y-5">
        <div class="flex gap-3">
          <div class="grid h-10 w-10 shrink-0 place-content-center rounded-full bg-slate-200 text-[var(--color-zapfe-amber)]">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-6-5.8-6-10a6 6 0 1 1 12 0c0 4.2-6 10-6 10z" /><circle cx="12" cy="11" r="2.5" /></svg>
          </div>
          <div>
            <h2 class="text-xl font-semibold text-[var(--color-zapfe-navy)]">Unser Standort</h2>
            <p class="text-slate-600">79104 Freiburg im Breisgau</p>
          </div>
        </div>

        <div class="flex gap-3">
          <div class="grid h-10 w-10 shrink-0 place-content-center rounded-full bg-slate-200 text-[var(--color-zapfe-amber)]">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="12" rx="2" /><path d="M4 8l8 6 8-6" /></svg>
          </div>
          <div>
            <h2 class="text-xl font-semibold text-[var(--color-zapfe-navy)]">E-Mail</h2>
            <p class="text-slate-700"><a href="mailto:info@zapfe.jetzt" class="hover:underline">info@zapfe.jetzt</a></p>
            <p class="text-sm text-slate-500">Wir antworten in der Regel innerhalb von 24 Stunden</p>
          </div>
        </div>

        <div class="flex gap-3">
          <div class="grid h-10 w-10 shrink-0 place-content-center rounded-full bg-slate-200 text-[var(--color-zapfe-amber)]">
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4h3l2 5-2 1.5a14 14 0 0 0 5.5 5.5L15 14l5 2v3a2 2 0 0 1-2.2 2A17 17 0 0 1 3 6.2 2 2 0 0 1 5 4z" /></svg>
          </div>
          <div>
            <h2 class="text-xl font-semibold text-[var(--color-zapfe-navy)]">Telefon</h2>
            <p class="text-slate-700"><a href="tel:+491623473520" class="hover:underline">+49 162 347 3520</a></p>
            <p class="text-sm text-slate-500">Verfügbar Montag-Freitag, 9-18 Uhr</p>
          </div>
        </div>
      </div>

      <div class="mt-8">
        <h2 class="text-2xl font-bold text-[var(--color-zapfe-navy)]">Wie du am schnellsten zum passenden Setup kommst</h2>
        <p class="mt-3 text-slate-600">Wenn dein Rahmen schon klar ist, starte direkt im <%= link_to "Preisrechner", calculator_path, class: "font-semibold text-[var(--color-zapfe-blue)]" %>. Wenn nicht, sortieren wir es hier gemeinsam.</p>
        <ol class="mt-3 list-decimal space-y-2 pl-5 text-slate-600">
          <li>Schick uns den Anlass, die Gästezahl und den gewünschten Zeitraum.</li>
          <li>Wir sagen dir, welches Setup realistisch und sinnvoll ist.</li>
          <li>Danach konkretisieren wir Getränke, Logistik und eventuelle Zusatzoptionen.</li>
        </ol>
        <div class="mt-6 space-y-3">
          <%= link_to "#{events_path}#event-einstieg", class: "link-panel block p-5" do %>
            <p class="text-sm font-semibold text-[var(--color-zapfe-navy)]">Direkt zu Veranstaltungen</p>
            <p class="mt-1 text-sm text-slate-600">Wenn du bereits weißt, dass es ein Event ist.</p>
          <% end %>
          <%= link_to "#{solutions_path}#anfrage", class: "link-panel block p-5" do %>
            <p class="text-sm font-semibold text-[var(--color-zapfe-navy)]">Direkt zu Solutions</p>
            <p class="mt-1 text-sm text-slate-600">Wenn es um dauerhaften Betrieb mit Selbstbedienung geht.</p>
          <% end %>
        </div>
      </div>
    </div>

    <div class="card-soft bg-[var(--color-zapfe-cream)] p-5 sm:p-6">
      <h2 class="text-2xl font-bold text-[var(--color-zapfe-navy)]">Kontaktformular</h2>

      <%= form_with model: Inquiry.new(source: "contact"), url: inquiries_path, class: "mt-4 space-y-3" do |f| %>
        <%= f.hidden_field :source, value: "contact" %>

        <div class="grid gap-3 sm:grid-cols-2">
          <div>
            <%= f.label :first_name, "Vorname *", class: "mb-1 block text-sm font-semibold text-[var(--color-zapfe-navy)]" %>
            <%= f.text_field :first_name, required: true, class: "w-full rounded-md border border-slate-300 bg-white px-3 py-2" %>
          </div>
          <div>
            <%= f.label :last_name, "Nachname *", class: "mb-1 block text-sm font-semibold text-[var(--color-zapfe-navy)]" %>
            <%= f.text_field :last_name, required: true, class: "w-full rounded-md border border-slate-300 bg-white px-3 py-2" %>
          </div>
          <div>
            <%= f.label :email, "E-Mail Adresse *", class: "mb-1 block text-sm font-semibold text-[var(--color-zapfe-navy)]" %>
            <%= f.email_field :email, required: true, class: "w-full rounded-md border border-slate-300 bg-white px-3 py-2" %>
          </div>
          <div>
            <%= f.label :phone, "Telefonnummer *", class: "mb-1 block text-sm font-semibold text-[var(--color-zapfe-navy)]" %>
            <%= f.telephone_field :phone, required: true, class: "w-full rounded-md border border-slate-300 bg-white px-3 py-2" %>
          </div>
        </div>

        <div>
          <%= f.label :event_type, "Veranstaltungstyp", class: "mb-1 block text-sm font-semibold text-[var(--color-zapfe-navy)]" %>
          <%= f.select :event_type, ["", "Firmenveranstaltung", "Hochzeit", "Private Feier", "Festival/Öffentliche Veranstaltung", "Sonstiges"], {}, class: "w-full rounded-md border border-slate-300 bg-white px-3 py-2" %>
        </div>
        <div>
          <%= f.label :guests, "Anzahl der Gäste", class: "mb-1 block text-sm font-semibold text-[var(--color-zapfe-navy)]" %>
          <%= f.number_field :guests, min: 1, class: "w-full rounded-md border border-slate-300 bg-white px-3 py-2" %>
        </div>
        <div>
          <%= f.label :message, "Zusätzliche Informationen", class: "mb-1 block text-sm font-semibold text-[var(--color-zapfe-navy)]" %>
          <%= f.text_area :message, rows: 3, class: "w-full rounded-md border border-slate-300 bg-white px-3 py-2" %>
        </div>

        <label class="flex items-start gap-2 text-xs text-slate-600">
          <%= f.check_box :privacy_accepted, required: true, class: "mt-0.5" %>
          <span>Mit dem Absenden erklären Sie sich mit unserer <%= link_to "Datenschutzerklärung", datenschutz_path, class: "font-semibold underline" %> einverstanden.</span>
        </label>

        <%= f.submit "Anfrage senden", class: "btn-primary mt-2 w-full" %>
      <% end %>
    </div>
  </div>
</section>
