<section class="py-6 sm:py-8 reveal" data-controller="reveal">
  <div class="page-wrap grid gap-6 lg:grid-cols-[minmax(0,1fr)_minmax(360px,0.95fr)] lg:items-start">
    <div class="space-y-6">
      <div class="card-soft p-5 sm:p-6">
        <span class="eyebrow-rule">Kontakt</span>
        <h1 class="mt-4 text-3xl font-bold text-[var(--color-zapfe-navy)]">Worum geht es?</h1>
        <p class="mt-3 max-w-2xl text-slate-600">Wenn dein Anliegen schon klar ist, geh direkt in den passenden Anfrageweg. Für alles Offene gibt es hier das freie Kontaktformular.</p>
      </div>

      <div class="grid gap-4">
        <%= link_to "#{events_path}#contact", class: "link-panel block p-5" do %>
          <p class="proof-kicker">Event</p>
          <h2 class="mt-3 text-xl font-semibold text-[var(--color-zapfe-navy)]">Zu Veranstaltungen</h2>
          <p class="mt-2 text-sm text-slate-600">Für Vermietung, Event-Setups und alle Anfragen rund um einzelne Einsätze.</p>
        <% end %>

        <%= link_to "#{solutions_path}#contact", class: "link-panel block p-5" do %>
          <p class="proof-kicker">Produkt</p>
          <h2 class="mt-3 text-xl font-semibold text-[var(--color-zapfe-navy)]">Zu Solutions</h2>
          <p class="mt-2 text-sm text-slate-600">Für dauerhaften Betrieb, feste Lösungen und Produktanfragen.</p>
        <% end %>
      </div>

      <div class="card-soft p-5 sm:p-6">
        <h2 class="text-2xl font-semibold text-[var(--color-zapfe-navy)]">Direkter Kontakt</h2>
        <div class="mt-5 space-y-5">
          <div class="flex gap-3">
            <div class="grid h-10 w-10 shrink-0 place-content-center rounded-full bg-slate-200 text-[var(--color-zapfe-amber)]">
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="12" rx="2" /><path d="M4 8l8 6 8-6" /></svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-[var(--color-zapfe-navy)]">E-Mail</h3>
              <p class="text-slate-700"><a href="mailto:info@zapfe.jetzt" class="hover:underline">info@zapfe.jetzt</a></p>
            </div>
          </div>

          <div class="flex gap-3">
            <div class="grid h-10 w-10 shrink-0 place-content-center rounded-full bg-slate-200 text-[var(--color-zapfe-amber)]">
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4h3l2 5-2 1.5a14 14 0 0 0 5.5 5.5L15 14l5 2v3a2 2 0 0 1-2.2 2A17 17 0 0 1 3 6.2 2 2 0 0 1 5 4z" /></svg>
            </div>
            <div>
              <h3 class="text-xl font-semibold text-[var(--color-zapfe-navy)]">Telefon</h3>
              <p class="text-slate-700"><a href="tel:+491623473520" class="hover:underline">+49 162 347 3520</a></p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="card-soft bg-[var(--color-zapfe-cream)] p-5 sm:p-6 lg:sticky lg:top-20">
      <h2 class="text-2xl font-bold text-[var(--color-zapfe-navy)]">Freie Anfrage</h2>
      <p class="mt-3 text-sm text-slate-600">Wenn dein Anliegen noch nicht klar zugeordnet ist, schreib uns hier direkt.</p>
      <div class="mt-4">
        <%= render "inquiry_form", source: "contact" %>
      </div>
    </div>
  </div>
</section>
