<% quick_products = (Array(@featured_products) + Array(@catalog_products)).uniq.first(12) %>

<section class="py-6 sm:py-10" data-controller="calculator">
  <div class="page-wrap max-w-7xl">
    <div class="mb-6 grid gap-5 lg:grid-cols-[minmax(0,1fr)_340px] lg:items-start xl:grid-cols-[minmax(0,1fr)_360px]">
      <div>
        <span class="eyebrow-rule">Event-Rechner</span>
        <h1 class="mt-4 text-3xl font-bold text-[var(--color-zapfe-navy)] sm:text-4xl">Preis kalkulieren</h1>
      </div>
      <aside class="card-soft p-5">
        <p class="proof-kicker">Wichtig</p>
        <p class="mt-3 text-sm leading-6 text-slate-600">Dieser Rechner ist nur für Veranstaltungen gedacht. Für dauerhaften Betrieb nutze bitte direkt <%= link_to "Solutions", "#{solutions_path}#contact", class: "font-semibold text-[var(--color-zapfe-blue)]" %>.</p>
      </aside>
    </div>

    <%= form_with model: Inquiry.new(source: "calculator"), url: inquiries_path, data: { turbo: false, controller: "form-validation" }, id: "calculator-form", class: "pb-28 lg:pb-0", lang: "de" do |f| %>
      <%= f.hidden_field :source, value: "calculator" %>
      <%= hidden_field_tag "inquiry[selected_product]", "Piaggio Ape", id: "selected-product-hidden" %>
      <%= f.hidden_field :rental_mode, id: "rental-mode-hidden" %>
      <%= f.hidden_field :rental_days, id: "rental-days-hidden" %>
      <%= f.hidden_field :start_time, id: "start-time-hidden", value: "" %>
      <%= f.hidden_field :end_time, id: "end-time-hidden", value: "" %>
      <%= f.hidden_field :bring_own_drinks, id: "bring-own-drinks-hidden", value: "0" %>
      <%= f.hidden_field :glasses_requested, id: "glasses-requested-hidden", value: "0" %>
      <%= f.hidden_field :selected_options, id: "selected-options" %>
      <%= f.hidden_field :total_price, id: "total-price-input" %>
      <%= f.hidden_field :pricing_snapshot, id: "pricing-snapshot" %>
      <%= f.hidden_field :event_date, id: "event-date-hidden" %>

      <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_340px] lg:gap-6 xl:grid-cols-[minmax(0,1fr)_360px]">
        <div class="space-y-5">
          <div class="card-soft p-5 sm:p-6">
            <p class="mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-zapfe-blue)]">Schritt 1</p>
            <h2 class="mb-4 text-2xl font-semibold text-[var(--color-zapfe-navy)]">Produkt wählen</h2>
            <div class="grid gap-4 xl:grid-cols-3">
              <div class="relative rounded-[1.5rem] border border-slate-200 bg-slate-50 p-4 xl:p-5">
                <div class="absolute left-4 top-5 z-10 rounded-full bg-white px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-700 shadow-sm ring-1 ring-slate-200">
                  Auf Anfrage in wenigen Wochen
                </div>
                <div class="flex flex-col gap-4 pt-10 opacity-55 xl:pt-12">
                  <div class="grid h-28 w-full place-items-center overflow-hidden rounded-2xl bg-white p-3 ring-1 ring-slate-200">
                    <%= image_tag "products/kiosk.png", alt: "Zapfe! Kiosk", class: "max-h-24 w-full object-contain object-center" %>
                  </div>
                  <div class="flex-1">
                    <p class="text-lg font-semibold text-slate-500">Zapfe! Kiosk</p>
                    <p class="mt-2 text-sm leading-6 text-slate-500">Einzelner Zapfhahn im kompakten Korpus.</p>
                  </div>
                </div>
              </div>

              <label class="rounded-[1.6rem] border border-[var(--color-zapfe-amber)] bg-[linear-gradient(180deg,#fffaf0_0%,#fff3d5_100%)] p-4 shadow-[0_12px_30px_rgba(214,180,63,0.14)] xl:p-5">
                <input type="radio" name="product_option" value="Zapfe! Multi" checked class="sr-only">
                <span class="flex h-full flex-col gap-4">
                  <span class="grid h-28 w-full place-items-center overflow-hidden rounded-2xl bg-white/80 p-3 ring-1 ring-amber-200">
                    <%= image_tag "products/multi.png", alt: "Zapfe! Multi", class: "max-h-24 w-full object-contain object-center" %>
                  </span>
                  <span class="flex-1">
                    <span class="block text-lg font-semibold text-[var(--color-zapfe-navy)]">Zapfe! Multi</span>
                    <span class="mt-2 block text-sm leading-6 text-slate-600">Mobile Lösung mit zwei Zapfhähnen in einer stilvollen Piaggio Ape.</span>
                  </span>
                </span>
              </label>

              <div class="relative rounded-[1.5rem] border border-slate-200 bg-slate-50 p-4 xl:p-5">
                <div class="absolute left-4 top-5 z-10 rounded-full bg-white px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-700 shadow-sm ring-1 ring-slate-200">
                  Auf Anfrage in wenigen Wochen
                </div>
                <div class="flex flex-col gap-4 pt-10 opacity-55 xl:pt-12">
                  <div class="grid h-28 w-full place-items-center overflow-hidden rounded-2xl bg-white p-3 ring-1 ring-slate-200">
                    <%= image_tag "products/wand.png", alt: "Zapfe! Wand", class: "max-h-24 w-full object-contain object-center" %>
                  </div>
                  <div class="flex-1">
                    <p class="text-lg font-semibold text-slate-500">Zapfe! Wand</p>
                    <p class="mt-2 text-sm leading-6 text-slate-500">Größere Lösung für hohe Frequenz.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="grid gap-5 xl:grid-cols-2">
            <div id="calculator-contact" class="card-soft p-5 sm:p-6">
              <p class="mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-zapfe-blue)]">Schritt 2</p>
              <h2 class="mb-3 text-2xl font-semibold text-[var(--color-zapfe-navy)]">Variante wählen</h2>
              <div class="space-y-3">
                <label class="flex items-start gap-3 rounded-md border border-slate-200 p-3">
                  <input type="radio" name="rental_option" value="zapf" data-base="250" checked class="mt-1">
                  <span><strong>Zapf (250€/Tag)</strong><br><span class="text-sm text-slate-500">Zapfanlage zur Selbstbedienung mit zwei Zapfhähnen</span></span>
                </label>
                <label class="flex items-start gap-3 rounded-md border border-slate-200 p-3">
                  <input type="radio" name="rental_option" value="self" data-base="350" class="mt-1">
                  <span><strong>Zapf & Pay (350€/Tag)</strong><br><span class="text-sm text-slate-500">Zapfanlage zur Selbstbedienung mit kontaktlosem Bezahlsystem</span></span>
                </label>
              </div>
            </div>

            <div class="card-soft p-5 sm:p-6">
              <p class="mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-zapfe-blue)]">Schritt 3</p>
              <h2 class="mb-3 text-2xl font-semibold text-[var(--color-zapfe-navy)]">Datum</h2>
              <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-1">
                <div>
                  <label for="rental-start-date" class="mb-1 block text-sm font-semibold text-[var(--color-zapfe-navy)]">Startdatum</label>
                  <%= date_field_tag "inquiry[starts_on]", nil, id: "rental-start-date", lang: "de", class: "w-full rounded-md border border-slate-300 bg-slate-50 px-3 py-2" %>
                </div>
                <div>
                  <label for="rental-end-date" class="mb-1 block text-sm font-semibold text-[var(--color-zapfe-navy)]">Enddatum</label>
                  <%= date_field_tag "inquiry[ends_on]", nil, id: "rental-end-date", lang: "de", class: "w-full rounded-md border border-slate-300 bg-slate-50 px-3 py-2" %>
                </div>
              </div>
              <p class="mt-3 text-sm text-slate-600">Mietdauer am Folgetag bis 13 Uhr inklusive. Exakter Zeitpunkt nach Absprache.</p>
              <p id="rental-summary" class="mt-2 text-sm text-slate-600"></p>
            </div>
          </div>

          <div class="card-soft p-5 sm:p-6">
        <p class="mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-zapfe-blue)]">Schritt 4</p>
        <h2 class="text-2xl font-semibold text-[var(--color-zapfe-navy)]">Getränke auswählen</h2>

        <label class="mt-4 flex cursor-pointer items-center justify-between gap-4 border-b border-slate-200 pb-4">
          <span class="min-w-0">
            <span class="block text-base font-semibold text-[var(--color-zapfe-navy)]">eigene Getränke</span>
          </span>
          <%= render "shared/toggle_switch", id: "bring-own-drinks", checked: false %>
        </label>

        <div id="calc-own-drinks-note" class="mt-4 hidden rounded-md border border-slate-200 bg-slate-50 p-4 text-sm text-slate-600">
          Du kümmerst dich um deine Getränke selbst. Wir können klassische Bierfässer mit Flachfitting und Softdrink-Fässer mit Korbfitting anschließen. Wenn dein Fass spezieller ist oder du dir unsicher bist, kontaktiere uns einfach.
        </div>

        <div id="calc-drinks-mode">
        <div class="mt-4 rounded-[1.4rem] border border-slate-200 bg-slate-50/70 p-4">
          <div class="grid gap-3 lg:grid-cols-[minmax(0,1fr)_auto_auto] lg:items-center">
            <div class="relative">
              <svg viewBox="0 0 24 24" class="pointer-events-none absolute left-3 top-2.5 h-5 w-5 text-slate-400" fill="none" stroke="currentColor" stroke-width="2"><path d="m21 21-4.35-4.35M10.5 18a7.5 7.5 0 1 1 0-15 7.5 7.5 0 0 1 0 15z"/></svg>
              <input id="calc-drinks-search" type="text" placeholder="Nach Getränken suchen..." class="w-full rounded-xl border border-slate-300 bg-white py-2 pl-10 pr-3" />
            </div>
            <label class="filter-pill">
              <input id="calc-filter-featured" type="checkbox" class="filter-pill-input">
              <span class="filter-pill-surface">
                <span class="filter-pill-indicator" aria-hidden="true">
                  <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                </span>
                <span class="featured-mark featured-mark--soft" aria-hidden="true">
                  <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 5h10v3H7z" />
                    <path d="M9 8v5a3 3 0 0 0 6 0V8" />
                    <path d="M8 19h8" />
                  </svg>
                </span>
                <span>Nur Zapfe!Tipps anzeigen</span>
              </span>
            </label>
            <%= link_to "-> zu allen Getränken", drinks_path, class: "btn-dark px-4 py-2 text-sm" %>
          </div>
        </div>

        <div class="relative">
          <button type="button" id="calc-scroll-left" class="absolute left-1 top-1/2 z-10 hidden -translate-y-1/2 rounded-full border border-slate-300 bg-white p-1.5 text-slate-600 lg:hidden">‹</button>
          <button type="button" id="calc-scroll-right" class="absolute right-1 top-1/2 z-10 hidden -translate-y-1/2 rounded-full border border-slate-300 bg-white p-1.5 text-slate-600 lg:hidden">›</button>

            <div id="calc-drinks-track" class="flex gap-3 overflow-x-auto pb-2 lg:grid lg:grid-cols-2 lg:overflow-visible xl:grid-cols-3" style="scroll-behavior:smooth;">
              <% quick_products.each do |product| %>
                <% variants = product.product_variants.order(size: :desc) %>
                <% next if variants.empty? %>
                <% display_label = short_product_label(product) %>
                <article class="calc-drink-card w-52 shrink-0 rounded-xl border border-slate-200 bg-white p-3 lg:w-auto lg:shrink lg:p-4" data-text="<%= [product.brand, product.name, product.kind, product.subcategory, product.featured_note].compact.join(' ') %>" data-featured="<%= product.featured? ? '1' : '0' %>">
                  <div class="relative mb-2 h-24 rounded-md bg-slate-50 p-2 lg:h-32">
                    <% if product.featured? %>
                      <button type="button" class="featured-corner-badge featured-corner-badge--soft" aria-label="Zapfe!-Tipps">
                        <svg viewBox="0 0 24 24" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M7 5h10v3H7z" />
                          <path d="M9 8v5a3 3 0 0 0 6 0V8" />
                          <path d="M8 19h8" />
                        </svg>
                        <span class="featured-corner-badge__tooltip">Zapfe!-Tipps</span>
                      </button>
                    <% end %>
                    <% unless product.is_alcoholic? %>
                      <span class="drink-attribute-badge" aria-label="Alkoholfrei">
                        <span class="drink-attribute-badge__text">0,0</span>
                      </span>
                    <% end %>
                    <%= product_card_image(product, width: 128, height: 96, img_class: "h-full w-full object-contain") %>
                  </div>
                  <p class="line-clamp-2 text-sm font-semibold text-[var(--color-zapfe-navy)]"><%= display_label %></p>
                                    <div class="mt-2 flex flex-wrap gap-1">
                    <% variants.each_with_index do |variant, idx| %>
                      <button
                        type="button"
                        class="calc-variant rounded border px-2 py-1 text-xs <%= idx.zero? ? 'border-[var(--color-zapfe-amber)] bg-[var(--color-zapfe-amber)]/20' : 'border-slate-300' %> <%= variant.is_available ? '' : 'opacity-40' %>"
                        data-size="<%= variant.size.to_f %>"
                        data-price="<%= variant.price.to_f %>"
                        data-available="<%= variant.is_available ? '1' : '0' %>"
                        data-selected="<%= idx.zero? ? '1' : '0' %>"
                        data-variant-id="<%= variant.id %>"
                        data-product-name="<%= product.name %>"
                        data-product-brand="<%= product.brand %>"
                        data-product-label="<%= display_label %>"
                      ><%= variant.size.to_f %>L</button>
                    <% end %>
                  </div>
                  <div class="mt-2 flex items-end justify-between">
                    <div>
                      <p class="calc-price text-sm font-bold text-slate-900"><%= number_to_currency(variants.first.price, unit: "€", separator: ",", delimiter: ".") %></p>
                      <p class="calc-price-per text-xs text-slate-500"><%= number_to_currency(variants.first.price.to_f / variants.first.size.to_f, unit: "€", separator: ",", delimiter: ".") %>/L</p>
                    </div>
                    <button type="button" class="calc-add-drink grid h-8 w-8 place-content-center rounded-full bg-[var(--color-zapfe-amber)] text-[var(--color-zapfe-navy)]" aria-label="Getränk hinzufügen">
                      <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
                    </button>
                  </div>
                </article>
              <% end %>
            </div>

          <div id="calc-no-results" class="card-soft hidden mx-auto mt-2 w-full max-w-md p-4 text-center text-sm text-slate-600" hidden>
            Kein Getränk gefunden. Versuche einen anderen Suchbegriff.
          </div>
        </div>
        </div>
      </div>

          <div class="card-soft p-5 sm:p-6">
            <p class="mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-zapfe-blue)]">Schritt 5</p>
            <h2 class="text-2xl font-semibold text-[var(--color-zapfe-navy)]">Unverbindlich anfragen</h2>
            <p class="mt-3 text-sm text-slate-600">Schick uns deine Anfrage. Wir melden uns zeitnah bei dir.</p>
            <div class="mt-5">
              <%= render "event_inquiry_fields", f: f, source: "calculator" %>
            </div>
          </div>
        </div>

        <aside class="mt-5 space-y-5 lg:sticky lg:top-24 lg:mt-0 lg:self-start">
          <div class="card-soft hidden p-5 lg:block">
            <div class="mb-3 flex items-center justify-between gap-3">
              <h2 class="text-2xl font-semibold text-[var(--color-zapfe-navy)]">Warenkorb</h2>
              <button id="calc-clear-cart" type="button" class="hidden rounded-md border border-slate-300 p-2 text-slate-500 hover:bg-slate-50 hover:text-slate-700" aria-label="Warenkorb leeren">
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M3 6h18" />
                  <path d="M8 6V4h8v2" />
                  <path d="M19 6l-1 14H6L5 6" />
                  <path d="M10 11v6M14 11v6" />
                </svg>
              </button>
            </div>
            <div id="calc-cart-items" class="space-y-3 text-sm text-slate-700"></div>
          </div>

          <div class="fixed inset-x-0 bottom-0 z-40 border-t border-white/10 bg-[var(--color-zapfe-navy)] px-3 pb-[max(0.75rem,env(safe-area-inset-bottom))] pt-3 text-white shadow-[0_-14px_30px_rgba(15,39,67,0.28)] lg:static lg:rounded-[1.8rem] lg:border lg:border-white/10 lg:px-5 lg:pb-5 lg:pt-5 lg:shadow-[0_24px_60px_rgba(15,39,67,0.24)]">
            <div class="flex items-start gap-2">
              <details id="pricing-breakdown" class="group min-w-0 flex-1 lg:[&_summary]:cursor-default">
                <summary class="flex cursor-pointer list-none items-center gap-2 rounded-xl border border-white/10 bg-white/5 px-2.5 py-2 lg:rounded-2xl lg:px-3 lg:py-3">
                  <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-white/10 bg-white/10 text-white">
                    <svg viewBox="0 0 24 24" class="h-4 w-4 transition group-open:rotate-180 lg:hidden" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                      <path d="M6 9l6 6 6-6" />
                    </svg>
                    <svg viewBox="0 0 24 24" class="hidden h-4 w-4 lg:block" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M12 5v14M5 12h14" />
                    </svg>
                  </span>
                  <span class="min-w-0 flex-1">
                    <span class="block text-[11px] font-semibold uppercase tracking-[0.14em] text-slate-300 sm:text-xs">Preisindikation</span>
                    <span class="flex items-baseline gap-2">
                      <strong id="total-price" class="text-lg sm:text-xl">€0,00</strong>
                      <span class="truncate text-[11px] text-slate-300 sm:text-xs">unverbindlich</span>
                    </span>
                  </span>
                </summary>
                <div id="pricing-breakdown-panel" class="mt-3 border-t border-white/10 pt-3 lg:block">
                  <div class="space-y-2 text-xs text-slate-200">
                    <div class="flex items-center justify-between gap-3">
                      <span id="pricing-rental-label">Miete</span>
                      <span id="pricing-rental-value">0,00 €</span>
                    </div>
                    <div id="pricing-drinks-row" class="flex items-center justify-between gap-3">
                      <span>Getränke</span>
                      <span id="pricing-drinks-value">0,00 €</span>
                    </div>
                    <div class="flex items-center justify-between gap-3 border-t border-white/10 pt-2 font-semibold text-white">
                      <span>Gesamt</span>
                      <span id="pricing-total-detail">0,00 €</span>
                    </div>
                  </div>
                  <p class="mt-3 text-[11px] text-slate-300">Orientierungswert für Veranstaltungen. Das finale Angebot stimmen wir mit dir direkt ab.</p>
                </div>
              </details>
              <a href="#calculator-contact" class="grid h-10 w-10 shrink-0 place-content-center rounded-xl bg-[var(--color-zapfe-amber)] text-[var(--color-zapfe-navy)]" aria-label="Zur Anfrage">
                <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h13" />
                  <path d="m12 5 7 7-7 7" />
                </svg>
              </a>
            </div>
          </div>
        </aside>
        </div>
    <% end %>
  </div>
</section>

<div id="calculator-confirm-overlay" class="fixed inset-0 z-[88] hidden bg-slate-950/35"></div>
<div id="calculator-confirm-sheet" class="fixed inset-x-0 bottom-0 z-[89] hidden rounded-t-[1.75rem] border border-slate-200 bg-white px-5 pb-[max(1.25rem,env(safe-area-inset-bottom))] pt-4 shadow-[0_-24px_60px_rgba(15,39,67,0.22)]">
  <div class="mx-auto mb-4 h-1.5 w-14 rounded-full bg-slate-200" aria-hidden="true"></div>
  <div class="mx-auto max-w-xl">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Warenkorb</p>
    <h2 class="mt-2 text-2xl font-semibold text-[var(--color-zapfe-navy)]">Wirklich leeren?</h2>
    <p class="mt-3 text-sm leading-6 text-slate-600">Alle ausgewählten Getränke werden aus dem Warenkorb entfernt.</p>
    <div class="mt-6 grid gap-3 sm:grid-cols-2">
      <button id="calculator-confirm-cancel" type="button" class="btn-dark w-full justify-center px-5 py-3">Abbrechen</button>
      <button id="calculator-confirm-clear" type="button" class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-[var(--color-zapfe-amber)] px-5 py-3 font-semibold text-[var(--color-zapfe-navy)] transition hover:brightness-[0.98]">
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 6h18" />
          <path d="M8 6V4h8v2" />
          <path d="M19 6l-1 14H6L5 6" />
          <path d="M10 11v6M14 11v6" />
        </svg>
        <span>Warenkorb leeren</span>
      </button>
    </div>
  </div>
</div>
