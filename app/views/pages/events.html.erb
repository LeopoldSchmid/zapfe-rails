<div data-controller="anchor-nav">
<section class="bg-slate-50 pt-8 pb-16 sm:pt-12 sm:pb-20">
  <div class="page-wrap">
    <div class="mx-auto max-w-4xl text-center">
      <span class="eyebrow-rule">Zapfe! Veranstaltungen</span>
      <h1 class="mt-4 text-4xl font-bold leading-[1.04] text-[var(--color-zapfe-navy)] sm:text-6xl">
        Frisch gezapfte Getränke für euere Veranstaltung
      </h1>
      <p class="mx-auto mt-5 max-w-3xl text-base leading-7 text-slate-600 sm:text-lg">
        Minimale Betreuung. Optionale Bezahlfunktion. Schnell aufgebaut.
      </p>
      <p class="mx-auto mt-3 max-w-2xl text-sm font-semibold uppercase tracking-[0.16em] text-slate-500 sm:text-base">
        Für kleine Feiern und große Veranstaltungen
      </p>
    </div>

    <figure class="solutions-media-frame mx-auto mt-10 max-w-5xl shadow-xl">
      <%= static_responsive_image_tag(
        base_name: "zapfe-event-exhibition",
        alt: "Zapfe! Piaggio Ape im Ausstellungsraum",
        width: 1440,
        height: 1176,
        img_class: "h-full w-full object-cover object-center",
        sizes: "(max-width: 1023px) 100vw, 1024px"
      ) %>
    </figure>
  </div>
</section>

<% solutions_film_url = ENV["SOLUTIONS_FILM_URL"].presence || "/videos/hochzeit_bier_horizontal_720.mp4" %>
<% hugo_video_url = ENV["HUGO_VIDEO_URL"].presence || "/videos/hochzeit_hugo_vertical_720.mp4" %>
<section id="event-einstieg" class="bg-[var(--color-zapfe-navy)] py-14 text-white sm:py-18">
  <div class="page-wrap">
    <div class="mx-auto grid max-w-6xl gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(360px,0.95fr)] lg:items-center">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--color-zapfe-amber)]">Produktfilm</p>
        <h2 class="mt-3 text-4xl font-bold leading-[1.05] sm:text-5xl">
          Liebe auf das erste Getränk.
        </h2>
        <p class="mt-4 max-w-2xl text-base leading-7 text-slate-200 sm:text-lg">
          Ausschank im echten Betrieb. Hier bei einer Hochzeit mit deaktivierter Bezahlfunktion.
        </p>
      </div>

      <div class="solutions-media-frame">
        <video
          autoplay
          loop
          muted
          playsinline
          preload="none"
          poster="/optimized/zapfe-hero-tablet.webp"
          class="aspect-video w-full object-cover"
          aria-label="Produktfilm Selbstbedienungsausschank"
          data-controller="lazy-video"
        >
          <source data-lazy-video-target="source" data-src="<%= solutions_film_url %>" type="video/mp4">
        </video>
      </div>
    </div>
  </div>
</section>

<section id="gross-event" class="bg-[var(--color-zapfe-cream)] py-14 sm:py-16">
  <div class="page-wrap">
    <div class="mb-8 max-w-3xl">
      <span class="eyebrow-rule">Mietoptionen</span>
      <h2 class="mt-4 text-3xl font-bold text-[var(--color-zapfe-navy)] sm:text-4xl">Was ihr mieten könnt.</h2>
      <p class="mt-3 text-slate-600">Einzelne Zapfhähne. Unsere Piaggio Ape mit zwei Zapfhähnen. Oder unsere Zapfe! Wand im Schiffscontainer für große Veranstaltungen.</p>
      <div class="mt-5 max-w-2xl rounded-[1.4rem] border border-amber-200/80 bg-[linear-gradient(180deg,rgba(255,252,244,0.98),rgba(255,246,219,0.92))] px-5 py-4 shadow-[0_14px_34px_rgba(214,180,63,0.12)]">
        <p class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">Aktueller Stand</p>
        <p class="mt-2 text-sm leading-6 text-slate-700">
          Kurzfristig verfügbar ist aktuell unsere <strong>Piaggio Ape</strong> mit zwei Zapfhähnen. Andere Lösungen sind auf Anfrage in der Regel innerhalb weniger Wochen möglich.
        </p>
      </div>
    </div>

    <div class="relative -mx-4">
      <div class="pointer-events-none absolute right-0 top-0 z-10 h-full w-8 bg-gradient-to-l from-[var(--color-zapfe-cream)] to-transparent lg:hidden"></div>
      <div class="flex snap-x snap-mandatory gap-4 overflow-x-auto px-4 pb-2 lg:mx-0 lg:grid lg:grid-cols-2 lg:gap-5 lg:overflow-visible lg:px-0 lg:pb-0 xl:grid-cols-3">
      <% [
        {
          title: "Zapfe! Kiosk",
          image_file: "kiosk.webp",
          body: "Unsere kompakteste und mobilste Lösung. Ein Zapfhahn in einer geschlossenen Kofferbox zum Aufstellen. Benötigt Stromanschluss. Fass ist im Korpus versteckt.",
          bullets: ["1 Zapfhahn", "Sehr Mobil", "Sehr Kompakt"]
        },
        {
          title: "Zapfe! Multi",
          image_file: "multi.webp",
          body: "Kompakte und mobile Lösung. Zwei bis drei Zapfhähne, bspw. in Piaggio Ape 50 verbaut. Kann selbstständig bewegt werden. Hoher Durchsatz. Kann zum Teil autonom, ohne Stromanschluss betrieben werden.",
          bullets: ["2-3 Zapfhähne", "Mobil", "Kompakt"]
        },
        {
          title: "Zapfe! Wand",
          image_file: "wand.webp",
          body: "3+ Zapfhähne. Verbaut in Schiffscontainer. Eingeschränkte Mobilität. Nicht selbstständig bewegbar. Sehr hoher Durchsatz.",
          bullets: ["3+ Zapfhähne", "Weniger kompakt", "Hoher Durchsatz"]
        }
      ].each do |system| %>
        <article class="card-soft flex-none snap-start overflow-hidden lg:flex lg:h-full lg:w-auto lg:max-w-none lg:flex-col" style="width:min(67vw,288px);min-width:min(67vw,288px);">
          <div class="flex h-full flex-col border-b border-slate-200 p-4">
            <div class="solutions-media-frame aspect-[16/10]">
              <%= image_tag "products/#{system[:image_file]}",
                alt: system[:title],
                class: "h-full w-full object-cover object-center",
                loading: "lazy" %>
            </div>
            <p class="mt-4 text-lg font-semibold text-[var(--color-zapfe-navy)]"><%= system[:title] %></p>
            <p class="mt-3 flex-1 text-sm leading-6 text-slate-600"><%= system[:body] %></p>
            <div class="mt-5 grid grid-cols-2 gap-2">
              <% system[:bullets].each_with_index do |bullet, index| %>
                <span class="<%= index.zero? ? 'col-span-2' : '' %> inline-flex items-center justify-center rounded-full bg-slate-100 px-3 py-1 text-center text-xs font-semibold text-slate-600"><%= bullet %></span>
              <% end %>
            </div>
          </div>
        </article>
      <% end %>
      </div>
    </div>
  </div>
</section>

<section class="bg-slate-50 py-14 sm:py-16">
  <div class="page-wrap">
    <div class="mx-auto max-w-6xl lg:grid lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center lg:gap-12">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-zapfe-blue)]">Getränkevielfalt</p>
        <h2 class="mt-3 text-4xl font-bold leading-[1.06] text-[var(--color-zapfe-navy)] sm:text-5xl">
          Nahezu alles zapfbar.
        </h2>
        <p class="mt-4 text-base leading-7 text-slate-600 sm:text-lg">
          Bier. Sekt. Limonade. Hugo. Spritz. Und vieles mehr. Flexibel für euer Getränkekonzept.
        </p>
        <div class="mt-6 text-left">
          <%= link_to "-> zur Getränkeauswahl", drinks_path, class: "btn-dark px-4 py-2 text-sm" %>
        </div>
      </div>

      <div class="solutions-media-frame beverage-video-frame mx-auto mt-8 lg:mt-0">
        <video
          autoplay
          loop
          muted
          playsinline
          preload="none"
          poster="/optimized/zapfe-hero-mobile.webp"
          class="aspect-[9/16] w-full object-cover"
          aria-label="Hugo wird gezapft"
          data-controller="lazy-video"
        >
          <source data-lazy-video-target="source" data-src="<%= hugo_video_url %>" type="video/mp4">
        </video>
      </div>
    </div>
  </div>
</section>

<section class="bg-white py-14 sm:py-16">
  <div class="page-wrap">
    <div class="mb-8 max-w-3xl">
      <span class="eyebrow-rule">Typische Engpässe</span>
      <h2 class="mt-4 text-3xl font-bold text-[var(--color-zapfe-navy)] sm:text-4xl">Die Highlights.</h2>
    </div>

    <div class="grid gap-5 lg:grid-cols-3">
      <% [
        {
          kicker: "Stoßzeiten",
          title: "Warteschlangen verkürzen",
          body: "Stoßzeiten sauber abfangen. Ohne zusätzlichen Personalbedarf.",
          image_file: "highlights_1.webp"
        },
        {
          kicker: "Ablauf",
          title: "Weniger Mitarbeiterdruck",
          body: "Mehr Durchsatz. Mehr Erlebnis für Gäste.",
          image_file: "highlights_2.webp"
        },
        {
          kicker: "Einbau",
          title: "Das passende Setup wählen",
          body: "Kiosk, Multi, Wand oder Speziallösung. Je nach Ort und Anforderungen.",
          image_file: "highlights_3.webp"
        }
      ].each do |benefit| %>
        <article class="benefit-visual-card">
          <div class="solutions-media-frame mb-4 aspect-[16/10]">
            <%= image_tag benefit[:image_file],
              alt: benefit[:title],
              class: "h-full w-full object-cover object-center",
              loading: "lazy" %>
          </div>
          <p class="proof-kicker"><%= benefit[:kicker] %></p>
          <p class="proof-value mt-3"><%= benefit[:title] %></p>
          <p class="mt-3 text-sm leading-6 text-slate-600"><%= benefit[:body] %></p>
          <p class="mt-4 text-xs font-semibold uppercase tracking-[0.16em] text-slate-400"><%= benefit[:detail] %></p>
        </article>
      <% end %>
    </div>
  </div>
</section>

<button
  type="button"
  data-anchor-nav-target="backButton"
  data-action="anchor-nav#back"
  class="btn-primary solutions-fab solutions-fab--back inline-flex h-12 w-12 items-center justify-center rounded-xl p-0 text-white sm:h-14 sm:w-14 lg:hidden"
  style="display:none;"
  aria-label="Zurück"
>
  <svg viewBox="0 0 24 24" class="h-5 w-5 sm:h-6 sm:w-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M15 18l-6-6 6-6" />
  </svg>
</button>

<a
  href="#contact"
  data-action="anchor-nav#jump"
  class="btn-primary solutions-fab solutions-fab--contact inline-flex h-12 w-12 items-center justify-center rounded-xl p-0 text-[var(--color-zapfe-navy)] sm:h-14 sm:w-14 lg:hidden"
  aria-label="Zur Anfrage springen"
>
  <svg viewBox="0 0 24 24" class="h-5 w-5 sm:h-6 sm:w-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M4 6h16v12H4z" />
    <path d="m4 8 8 5 8-5" />
  </svg>
</a>

<section id="contact" class="bg-white py-14 sm:py-18">
  <div class="page-wrap">
    <div id="anfrage"></div>
    <div class="card-soft p-7 sm:p-10">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(320px,0.9fr)] lg:items-start">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-zapfe-blue)]">Anfrage</p>
          <h2 class="mt-3 text-3xl font-bold text-[var(--color-zapfe-navy)] sm:text-4xl">Jetzt Vermietung anfragen</h2>
          <p class="mt-4 max-w-2xl text-slate-600">Frag uns an. Wir melden uns bei dir. Detaillierte Preisinformationen findest du im Preisrechner</p>
          
        </div>

        <div class="rounded-3xl border border-slate-200 bg-[var(--color-zapfe-cream)] p-5 sm:p-6">
          <%= form_with model: Inquiry.new(source: "events"), url: inquiries_path, class: "space-y-4", data: { controller: "form-validation" }, lang: "de" do |f| %>
            <%= f.hidden_field :source, value: "events" %>
            <%= render "pages/spam_protection_fields", field_name_prefix: "inquiry", field_prefix: "events-inquiry" %>
            <%= render "event_inquiry_fields", f: f, source: "events" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
</div>
