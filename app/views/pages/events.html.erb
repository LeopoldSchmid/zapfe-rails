<section class="bg-white py-16">
  <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-10 text-center">
      <h1 class="text-4xl font-bold text-[#1E293B]">Vergangene Veranstaltungen</h1>
      <p class="mt-4 text-lg text-slate-600">Beispiele aus Events, bei denen Zapfe im Einsatz war.</p>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      <% @events.each do |event| %>
        <article class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-slate-100">
          <% if event.image.attached? %>
            <%= image_tag event.image, class: "h-64 w-full object-cover" %>
          <% else %>
            <img src="/placeholder.svg" alt="Event" class="h-64 w-full bg-slate-100 object-cover p-14" />
          <% end %>
          <div class="p-6">
            <div class="mb-3 flex items-center justify-between gap-4">
              <h2 class="text-2xl font-semibold text-[#1E293B]"><%= event.title %></h2>
              <% if event.date_from.present? %>
                <span class="rounded-full bg-[#F2C94C]/25 px-3 py-1 text-sm font-medium text-[#1E293B]"><%= l(event.date_from) %></span>
              <% end %>
            </div>
            <% if event.subtitle.present? %><p class="mb-2 text-sm font-medium text-[#345995]"><%= event.subtitle %></p><% end %>
            <p class="text-slate-600"><%= event.description %></p>
            <% if event.location.present? %><p class="mt-3 text-sm text-slate-500">Ort: <%= event.location %></p><% end %>
            <% if event.instagram_url.present? %>
              <%= link_to "Instagram Post", event.instagram_url, class: "mt-4 inline-block font-semibold text-[#345995] hover:underline", target: "_blank", rel: "noopener" %>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  </div>
</section>
