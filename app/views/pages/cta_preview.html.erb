<section class="bg-[linear-gradient(180deg,#fffdf7_0%,#fff8e7_42%,#f8fafc_100%)] py-10 sm:py-14">
  <div class="page-wrap space-y-8 sm:space-y-10">
    <header class="mx-auto max-w-3xl text-center">
      <span class="eyebrow-rule">CTA Studien</span>
      <h1 class="mt-4 text-4xl font-bold leading-[1.02] text-[var(--color-zapfe-navy)] sm:text-6xl">
        Frisch gezapfte Getränke zur Selbstbedienung.
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-slate-600 sm:text-lg">
        Autonomer Betrieb. Selbstbedienung. Optionale Bezahlfunktion.
      </p>
      <p class="mx-auto mt-4 max-w-2xl text-sm leading-6 text-slate-500 sm:text-base">
        Gleiche Copy, drei Richtungen fuer den Einstieg. Entscheidend ist nur die Wahl der CTA-Sprache.
      </p>
    </header>

    <article class="cta-study-shell">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="cta-study-label">Variante 1</p>
          <h2 class="mt-1 text-2xl font-bold text-[var(--color-zapfe-navy)]">Compact Pill</h2>
        </div>
        <p class="cta-study-note max-w-2xl">
          Der direkteste Button. Flacher, klarer, mit Pfeil und deutlich sichtbarer Klickrichtung.
        </p>
      </div>

      <div class="cta-pill-grid mt-5">
        <%= link_to events_path, class: "cta-pill cta-pill--event" do %>
          <span class="cta-pill__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" class="h-4.5 w-4.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 4v3M17 4v3M4.5 9.5h15M6 20h12a1.5 1.5 0 0 0 1.5-1.5V8A1.5 1.5 0 0 0 18 6.5H6A1.5 1.5 0 0 0 4.5 8v10.5A1.5 1.5 0 0 0 6 20Z" />
            </svg>
          </span>
          <span class="cta-pill__copy">
            <span class="cta-pill__tag">Event</span>
            <span class="cta-pill__title">Temporär</span>
          </span>
          <span class="cta-pill__arrow" aria-hidden="true">→</span>
        <% end %>

        <%= link_to solutions_path, class: "cta-pill cta-pill--solutions" do %>
          <span class="cta-pill__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" class="h-4.5 w-4.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 19V8.5A1.5 1.5 0 0 1 6.5 7h11A1.5 1.5 0 0 1 19 8.5V19" />
              <path d="M9 19v-4h6v4" />
            </svg>
          </span>
          <span class="cta-pill__copy">
            <span class="cta-pill__tag">Betrieb</span>
            <span class="cta-pill__title">Dauerhaft</span>
          </span>
          <span class="cta-pill__arrow" aria-hidden="true">→</span>
        <% end %>
      </div>
    </article>

    <article class="cta-study-shell">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="cta-study-label">Variante 2</p>
          <h2 class="mt-1 text-2xl font-bold text-[var(--color-zapfe-navy)]">Split Button</h2>
        </div>
        <p class="cta-study-note max-w-2xl">
          Zwei Zonen in einem Button. Links Orientierung, rechts Aktion. Etwas präziser und technischer.
        </p>
      </div>

      <div class="cta-split-grid mt-5">
        <%= link_to events_path, class: "cta-split cta-split--event" do %>
          <span class="cta-split__lead">
            <span class="cta-split__tag">Event</span>
            <span class="cta-split__title">Temporär</span>
          </span>
          <span class="cta-split__trail">
            <span class="cta-split__hint">Wählen</span>
            <span class="cta-split__arrow" aria-hidden="true">→</span>
          </span>
        <% end %>

        <%= link_to solutions_path, class: "cta-split cta-split--solutions" do %>
          <span class="cta-split__lead">
            <span class="cta-split__tag">Betrieb</span>
            <span class="cta-split__title">Dauerhaft</span>
          </span>
          <span class="cta-split__trail">
            <span class="cta-split__hint">Wählen</span>
            <span class="cta-split__arrow" aria-hidden="true">→</span>
          </span>
        <% end %>
      </div>
    </article>

    <article class="cta-study-shell">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="cta-study-label">Variante 3</p>
          <h2 class="mt-1 text-2xl font-bold text-[var(--color-zapfe-navy)]">Mini Card CTA</h2>
        </div>
        <p class="cta-study-note max-w-2xl">
          Die starke Variante 3, aber deutlich gestrafft. Mehr Charakter als ein Button, ohne wie eine Inhaltskarte zu wirken.
        </p>
      </div>

      <div class="cta-mini-grid mt-5">
        <%= link_to events_path, class: "cta-mini cta-mini--event" do %>
          <span class="cta-mini__topline">
            <span class="cta-mini__tag">Event</span>
            <span class="cta-mini__arrow" aria-hidden="true">→</span>
          </span>
          <span class="cta-mini__title">Temporär</span>
        <% end %>

        <%= link_to solutions_path, class: "cta-mini cta-mini--solutions" do %>
          <span class="cta-mini__topline">
            <span class="cta-mini__tag">Betrieb</span>
            <span class="cta-mini__arrow" aria-hidden="true">→</span>
          </span>
          <span class="cta-mini__title">Dauerhaft</span>
        <% end %>
      </div>
    </article>
  </div>
</section>
