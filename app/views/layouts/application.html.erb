<!DOCTYPE html>
<html lang="de">
  <head>
    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= page_description %>">
    <meta name="author" content="Zapfe!">
    <meta name="robots" content="index,follow">
    <link rel="canonical" href="<%= canonical_url %>">
    <meta property="og:site_name" content="Zapfe!">
    <meta property="og:type" content="website">
    <meta property="og:title" content="<%= page_title %>">
    <meta property="og:description" content="<%= page_description %>">
    <meta property="og:url" content="<%= canonical_url %>">
    <meta property="og:image" content="<%= og_image_url %>">
    <% if og_image_secure_url.present? %>
      <meta property="og:image:secure_url" content="<%= og_image_secure_url %>">
    <% end %>
    <meta property="og:image:type" content="<%= og_image_type %>">
    <meta property="og:image:width" content="<%= og_image_width %>">
    <meta property="og:image:height" content="<%= og_image_height %>">
    <meta property="og:image:alt" content="<%= og_image_alt %>">
    <meta property="og:locale" content="de_DE">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= page_title %>">
    <meta name="twitter:description" content="<%= page_description %>">
    <meta name="twitter:image" content="<%= og_image_url %>">
    <meta name="twitter:image:alt" content="<%= og_image_alt %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/zapfe_b_w.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/zapfe_b_w.svg">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
    <%= content_tag(:script, raw(json_escape(page_json_ld.to_json)), type: "application/ld+json", nonce: content_security_policy_nonce) %>
  </head>

  <body class="bg-slate-50 text-slate-900" data-controller="page-transition">
    <div id="site-header">
      <%= render "shared/navbar" %>
    </div>

    <main id="page-content" class="<%= main_container_classes %>">
      <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
        <% flash.each do |type, message| %>
          <% tone = type.to_s == "alert" ? "bg-red-100 text-red-800" : "bg-emerald-100 text-emerald-800" %>
          <div class="mt-4 rounded-lg px-4 py-3 text-sm <%= tone %>"><%= message %></div>
        <% end %>
      </div>
      <%= yield %>
    </main>

    <%= render "shared/footer" %>
  </body>
</html>
