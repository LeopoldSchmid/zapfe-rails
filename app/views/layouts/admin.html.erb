<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Zapfe Admin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-slate-100 text-slate-900">
    <header class="sticky top-0 z-20 border-b border-slate-200 bg-white">
      <div class="mx-auto flex w-full max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
        <%= link_to "Zapfe Admin", admin_root_path, class: "text-xl font-semibold text-slate-900" %>
        <nav class="flex items-center gap-4 text-sm">
          <%= link_to "Dashboard", admin_root_path, class: "text-slate-700 hover:text-slate-900" %>
          <%= link_to "Produkte", admin_products_path, class: "text-slate-700 hover:text-slate-900" %>
          <%= link_to "Kategorien", admin_categories_path, class: "text-slate-700 hover:text-slate-900" %>
          <%= link_to "Events", admin_events_path, class: "text-slate-700 hover:text-slate-900" %>
          <%= button_to "Logout", admin_logout_path, method: :delete, class: "rounded bg-slate-900 px-3 py-1.5 text-white" %>
        </nav>
      </div>
    </header>

    <main class="mx-auto w-full max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
      <% flash.each do |type, message| %>
        <% tone = type.to_s == "alert" ? "bg-red-100 text-red-800" : "bg-emerald-100 text-emerald-800" %>
        <div class="mb-4 rounded-lg px-4 py-3 text-sm <%= tone %>"><%= message %></div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
