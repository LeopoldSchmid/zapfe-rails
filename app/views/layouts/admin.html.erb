<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Zapfe Admin" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="admin-shell text-slate-900">
    <header class="admin-topbar">
      <div class="admin-container flex flex-col gap-4 py-4 lg:flex-row lg:items-center lg:justify-between">
        <div>
          <%= link_to "Zapfe Admin", admin_root_path, class: "text-xl font-semibold text-slate-900" %>
          <p class="mt-1 text-sm text-slate-500">Produkte, Events und Katalogdaten in einem klaren Arbeitsbereich.</p>
        </div>
        <nav class="flex flex-wrap items-center gap-3 text-sm">
          <%= link_to "Dashboard", admin_root_path, class: "admin-link" %>
          <%= link_to "Produkte", admin_products_path, class: "admin-link" %>
          <%= link_to "Kategorien", admin_categories_path, class: "admin-link" %>
          <%= link_to "Events", admin_events_path, class: "admin-link" %>
          <%= button_to "Logout", admin_logout_path, method: :delete, class: "admin-cta" %>
        </nav>
      </div>
    </header>

    <main class="admin-container py-6">
      <% flash.each do |type, message| %>
        <% tone = type.to_s == "alert" ? "bg-red-100 text-red-800" : "bg-emerald-100 text-emerald-800" %>
        <div class="mb-4 rounded-lg px-4 py-3 text-sm <%= tone %>"><%= message %></div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
