<h1 class="mb-6 text-2xl font-semibold">Dashboard</h1>

<div class="grid gap-4 md:grid-cols-3">
  <div class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
    <p class="text-sm text-slate-500">Produkte</p>
    <p class="mt-2 text-3xl font-bold text-slate-900"><%= @products_count %></p>
  </div>

  <div class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
    <p class="text-sm text-slate-500">Events</p>
    <p class="mt-2 text-3xl font-bold text-slate-900"><%= @events_count %></p>
  </div>

  <div class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
    <p class="text-sm text-slate-500">Anfragen</p>
    <p class="mt-2 text-3xl font-bold text-slate-900"><%= @inquiries_count %></p>
  </div>
</div>
