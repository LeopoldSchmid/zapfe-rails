<p class="proof-kicker">Geschützter Bereich</p>
<h1 class="mb-2 mt-2 text-2xl font-semibold text-slate-900">Admin Login</h1>
<p class="mb-6 text-sm text-slate-500">Melde dich an, um Katalog, Events und Inhalte zu bearbeiten.</p>

<%= form_with url: admin_login_path, class: "space-y-4" do |f| %>
  <div>
    <%= f.label :email, class: "mb-1 block text-sm font-medium" %>
    <%= f.email_field :email, required: true, class: "w-full rounded-md border border-slate-300 px-3 py-2" %>
  </div>

  <div>
    <%= f.label :password, class: "mb-1 block text-sm font-medium" %>
    <%= f.password_field :password, required: true, class: "w-full rounded-md border border-slate-300 px-3 py-2" %>
  </div>

  <%= f.submit "Einloggen", class: "admin-cta w-full" %>
<% end %>

<p class="mt-4 text-center text-sm text-slate-500">
  <%= link_to "Passwort vergessen?", admin_new_password_path, class: "font-medium text-slate-700 hover:underline" %>
</p>
