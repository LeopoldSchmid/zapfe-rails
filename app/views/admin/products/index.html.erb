<div class="mb-4 flex items-center justify-between">
  <h1 class="text-2xl font-semibold">Produkte</h1>
  <%= link_to "Neues Produkt", new_admin_product_path, class: "rounded bg-slate-900 px-3 py-2 text-sm text-white" %>
</div>

<div class="grid gap-4 md:grid-cols-2">
  <% @products.each do |product| %>
    <article class="rounded-xl bg-white p-4 shadow-sm ring-1 ring-slate-200">
      <div class="mb-3">
        <% if product.image.attached? %>
          <%= image_tag product.image, class: "h-32 w-full rounded-lg object-contain bg-slate-50" %>
        <% else %>
          <img src="/placeholder-bottle.png" alt="Kein Bild" class="h-32 w-full rounded-lg object-contain bg-slate-50 p-3" />
        <% end %>
      </div>
      <h2 class="text-lg font-semibold"><%= product.brand %> <%= product.name %></h2>
      <p class="mt-1 text-sm text-slate-600"><%= product.article_number %> • <%= product.kind %></p>
      <ul class="mt-3 space-y-1 text-sm text-slate-700">
        <% product.product_variants.each do |variant| %>
          <li><%= variant.sku %> • <%= variant.size.to_f %>L • <%= number_to_currency(variant.price, unit: "€", separator: ",", delimiter: ".") %></li>
        <% end %>
      </ul>
      <div class="mt-3 flex gap-3 text-sm">
        <%= link_to "Bearbeiten", edit_admin_product_path(product), class: "text-slate-700 hover:underline" %>
        <%= button_to "Löschen", admin_product_path(product), method: :delete, class: "text-red-700", form: { class: "inline" } %>
      </div>
    </article>
  <% end %>
</div>
