<div class="admin-toolbar">
  <div>
    <p class="proof-kicker">Katalog</p>
    <h1 class="mt-2 text-3xl font-semibold text-[var(--color-zapfe-navy)]">Produkte</h1>
  </div>
  <%= link_to "Neues Produkt", new_admin_product_path, class: "admin-cta" %>
</div>

<div class="grid gap-4 md:grid-cols-2">
  <% @products.each do |product| %>
    <article class="admin-panel">
      <div class="mb-3">
        <% if product.image.attached? %>
          <%= image_tag product.image, class: "h-32 w-full rounded-lg object-contain bg-slate-50" %>
        <% else %>
          <img src="/placeholder-bottle.png" alt="Kein Bild" class="h-32 w-full rounded-lg object-contain bg-slate-50 p-3" />
        <% end %>
      </div>
      <div class="flex flex-wrap items-start justify-between gap-2">
        <h2 class="text-lg font-semibold"><%= product.brand %> <%= product.name %></h2>
        <% if product.featured? %>
          <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-amber-800">Favorit <% if product.featured_position.present? %>• <%= product.featured_position %><% end %></span>
        <% end %>
      </div>
      <p class="mt-1 text-sm text-slate-600"><%= product.article_number %> • <%= product.kind %></p>
      <% if product.featured? %>
        <p class="mt-2 text-sm text-slate-600"><%= product_featured_note(product) %></p>
      <% end %>
      <ul class="mt-3 space-y-1 text-sm text-slate-700">
        <% product.product_variants.each do |variant| %>
          <li><%= variant.sku %> • <%= variant.size.to_f %>L • <%= number_to_currency(variant.price, unit: "€", separator: ",", delimiter: ".") %></li>
        <% end %>
      </ul>
      <div class="mt-3 flex gap-3 text-sm">
        <%= link_to "Bearbeiten", edit_admin_product_path(product), class: "font-medium text-slate-700 hover:underline" %>
        <%= button_to "Löschen", admin_product_path(product), method: :delete, class: "text-red-700", form: { class: "inline" } %>
      </div>
    </article>
  <% end %>
</div>
