<%= render "shared/form_errors", object: @product %>

<%= form_with model: [ :admin, @product ], class: "space-y-4" do |f| %>
  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= f.label :article_number, class: "mb-1 block text-sm font-medium" %>
      <%= f.text_field :article_number, required: true, class: "w-full rounded-md border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= f.label :category_id, "Kategorie", class: "mb-1 block text-sm font-medium" %>
      <%= f.collection_select :category_id, @categories, :id, :name, include_blank: true, class: "w-full rounded-md border border-slate-300 px-3 py-2" %>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-3">
    <div>
      <%= f.label :brand, class: "mb-1 block text-sm font-medium" %>
      <%= f.text_field :brand, required: true, class: "w-full rounded-md border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= f.label :name, class: "mb-1 block text-sm font-medium" %>
      <%= f.text_field :name, required: true, class: "w-full rounded-md border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= f.label :kind, "Typ", class: "mb-1 block text-sm font-medium" %>
      <%= f.text_field :kind, required: true, class: "w-full rounded-md border border-slate-300 px-3 py-2" %>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2">
    <div>
      <%= f.label :subcategory, class: "mb-1 block text-sm font-medium" %>
      <%= f.text_field :subcategory, class: "w-full rounded-md border border-slate-300 px-3 py-2" %>
    </div>
    <div>
      <%= f.label :alcohol_content, class: "mb-1 block text-sm font-medium" %>
      <%= f.number_field :alcohol_content, step: 0.1, class: "w-full rounded-md border border-slate-300 px-3 py-2" %>
    </div>
  </div>

  <label class="inline-flex items-center gap-2">
    <%= f.check_box :is_alcoholic %> Alkoholisch
  </label>

  <div>
    <%= f.label :description, class: "mb-1 block text-sm font-medium" %>
    <%= f.text_area :description, rows: 4, class: "w-full rounded-md border border-slate-300 px-3 py-2" %>
  </div>

  <div>
    <%= f.label :image, "Produktbild", class: "mb-1 block text-sm font-medium" %>
    <%= f.file_field :image, accept: "image/*", class: "w-full rounded-md border border-slate-300 px-3 py-2" %>
    <% if @product.image.attached? %>
      <div class="mt-3">
        <p class="mb-1 text-xs text-slate-500">Aktuelles Bild</p>
        <%= image_tag @product.image, class: "h-32 w-32 rounded-md object-cover ring-1 ring-slate-200" %>
      </div>
    <% end %>
  </div>

  <div class="rounded-lg border border-slate-200 p-4">
    <h3 class="mb-3 font-semibold">Varianten</h3>
    <%= f.fields_for :product_variants do |vf| %>
      <div class="mb-3 grid gap-3 rounded-md border border-slate-200 p-3 md:grid-cols-6">
        <%= vf.hidden_field :id %>
        <div>
          <%= vf.label :sku, class: "mb-1 block text-xs font-medium" %>
          <%= vf.text_field :sku, class: "w-full rounded border border-slate-300 px-2 py-1" %>
        </div>
        <div>
          <%= vf.label :size, class: "mb-1 block text-xs font-medium" %>
          <%= vf.number_field :size, step: 0.1, class: "w-full rounded border border-slate-300 px-2 py-1" %>
        </div>
        <div>
          <%= vf.label :price, class: "mb-1 block text-xs font-medium" %>
          <%= vf.number_field :price, step: 0.01, class: "w-full rounded border border-slate-300 px-2 py-1" %>
        </div>
        <div>
          <%= vf.label :availability, class: "mb-1 block text-xs font-medium" %>
          <%= vf.text_field :availability, class: "w-full rounded border border-slate-300 px-2 py-1" %>
        </div>
        <label class="mt-6 inline-flex items-center gap-1 text-xs">
          <%= vf.check_box :is_available %> Aktiv
        </label>
        <label class="mt-6 inline-flex items-center gap-1 text-xs text-red-700">
          <%= vf.check_box :_destroy %> Löschen
        </label>
      </div>
    <% end %>
  </div>

  <%= f.submit class: "rounded bg-slate-900 px-4 py-2 text-white" %>
<% end %>
