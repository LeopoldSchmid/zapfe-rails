<p class="proof-kicker">Admin Zugang</p>
<h1 class="mb-2 mt-2 text-2xl font-semibold text-slate-900">Passwort zurücksetzen</h1>
<p class="mb-6 text-sm text-slate-500">Wir senden dir einen sicheren Link zum Setzen eines neuen Admin-Passworts.</p>

<%= form_with url: admin_password_path, class: "space-y-4" do |f| %>
  <div>
    <%= f.label :email, "Admin-E-Mail", class: "mb-1 block text-sm font-medium" %>
    <%= f.email_field :email, required: true, autocomplete: "email", class: "w-full rounded-md border border-slate-300 px-3 py-2" %>
  </div>

  <%= f.submit "Reset-Link senden", class: "admin-cta w-full" %>
<% end %>

<p class="mt-4 text-center text-sm text-slate-500">
  <%= link_to "Zurück zum Login", admin_login_path, class: "font-medium text-slate-700 hover:underline" %>
</p>
