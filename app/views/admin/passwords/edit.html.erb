<p class="proof-kicker">Admin Zugang</p>
<h1 class="mb-2 mt-2 text-2xl font-semibold text-slate-900">Neues Passwort setzen</h1>
<p class="mb-6 text-sm text-slate-500">Vergib jetzt ein neues sicheres Passwort für den Admin-Zugang.</p>

<%= form_with url: admin_edit_password_path(token: params[:token]), method: :patch, class: "space-y-4" do |f| %>
  <div>
    <%= f.label :password, "Neues Passwort", class: "mb-1 block text-sm font-medium" %>
    <%= f.password_field :password, required: true, autocomplete: "new-password", class: "w-full rounded-md border border-slate-300 px-3 py-2" %>
  </div>

  <div>
    <%= f.label :password_confirmation, "Passwort bestätigen", class: "mb-1 block text-sm font-medium" %>
    <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password", class: "w-full rounded-md border border-slate-300 px-3 py-2" %>
  </div>

  <%= f.submit "Passwort speichern", class: "admin-cta w-full" %>
<% end %>
