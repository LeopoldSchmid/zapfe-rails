<div class="admin-toolbar">
  <div>
    <p class="proof-kicker">Inhalte</p>
    <h1 class="mt-2 text-3xl font-semibold text-[var(--color-zapfe-navy)]">Events</h1>
  </div>
  <%= link_to "Neues Event", new_admin_event_path, class: "admin-cta" %>
</div>

<div class="grid gap-4 md:grid-cols-2">
  <% @events.each do |event| %>
    <article class="admin-panel">
      <h2 class="text-lg font-semibold"><%= event.title %></h2>
      <p class="mt-1 text-sm text-slate-600"><%= event.date_from ? l(event.date_from) : "Kein Datum" %></p>
      <p class="mt-2 text-sm text-slate-600"><%= event.description&.truncate(120) %></p>
      <div class="mt-3 flex gap-3 text-sm">
        <%= link_to "Bearbeiten", edit_admin_event_path(event), class: "text-slate-700 hover:underline" %>
        <%= button_to "Löschen", admin_event_path(event), method: :delete, class: "text-red-700", form: { class: "inline" } %>
      </div>
    </article>
  <% end %>
</div>
